# ─── App ────────────────────────────────────────────
APP_NAME=DoctorFinder API
DEBUG=True

# ─── Database (PostgreSQL) ──────────────────────────
# Replace YOUR_PG_PASSWORD with your actual PostgreSQL password
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PG_PASSWORD@localhost:5432/doctorfinder
DATABASE_URL_SYNC=postgresql://postgres:YOUR_PG_PASSWORD@localhost:5432/doctorfinder

# ─── Redis ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300
SEARCH_CACHE_TTL=60

# ─── Elasticsearch ──────────────────────────────────
# ES 8/9 starts with HTTPS + security enabled by default
ELASTICSEARCH_URL=https://localhost:9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=DLMoTp=ZJrc6PL8XM9xS
ELASTICSEARCH_INDEX_DOCTORS=doctors
ELASTICSEARCH_VERIFY_CERTS=False

# ─── JWT ────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30
